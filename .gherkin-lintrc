{
  "no-unnamed-features": "on",
  "no-unnamed-scenarios": "on",
  "no-empty-file": "on",
  "no-files-without-scenarios": "on",
  "no-dupe-feature-names": "on",
  "no-dupe-scenario-names": ["on", "in-feature"],
  "no-duplicate-tags": "on",
  "no-homogenous-tags": "on",
  "no-scenario-outlines-without-examples": "on",
  "no-examples-in-scenarios": "on",
  "no-partially-commented-tag-lines": "on",
  "no-trailing-spaces": "on",
  "no-multiple-empty-lines": "on",
  "new-line-at-eof": ["on", "yes"],
  "indentation": ["on", { "Feature": 0, "Background": 2, "Scenario": 2, "Step": 4, "Examples": 4, "example": 6, "given": 4, "when": 4, "then": 4, "and": 4, "but": 4 }],
  "name-length": ["on", { "Feature": 70, "Scenario": 90, "Step": 120 }],
  "scenario-size": ["on", { "steps-length": { "Background": 12, "Scenario": 12 }}]
}